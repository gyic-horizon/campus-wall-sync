{
    "app": {
        "debug": false,
        "host": "0.0.0.0",
        "port": 5000,
        "log_level": "INFO"
    },
    "halo": {
        "api_url": "https://your-halo-site.com",
        "api_token": "your-api-token-here",
        "site_name": "campus-blog",
        "timeout": 30,
        "default_category": "表白墙",
        "default_tags": ["投稿", "校园墙"]
    },
    "questionnaire": {
        "webhook_token": "your-questionnaire-webhook-token",
        "enabled": true
    },
    "review": {
        "enable_ai_review": false,
        "ai_review_type": "openai",
        "openai_api_key": "your-openai-api-key"
    }
}
